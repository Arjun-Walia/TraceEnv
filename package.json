{
  "name": "traceenv",
  "version": "0.1.0",
  "description": "Local-first workspace synthesizer that generates reproducible setup documentation from real terminal workflows",
  "main": "dist/cli/index.js",
  "bin": {
    "trace": "dist/cli/index.js",
    "traceenv": "dist/cli/index.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "ts-node src/cli/index.ts",
    "start": "node dist/cli/index.js",
    "daemon:dev": "ts-node src/daemon/index.ts"
  },
  "dependencies": {
    "commander": "^12.0.0",
    "prompts": "^2.4.2"
  },
  "optionalDependencies": {
    "node-llama-cpp": "^3.1.1"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "@types/prompts": "^2.4.9",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.3"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "keywords": ["devtools", "documentation", "shell", "local-ai", "workflow"],
  "license": "MIT"
}
